module Semantics.Marking.Judgment where

open import Data.Nat hiding (_+_; _вКФ_)
open import Data.Maybe
open import Data.List
open import Relation.Binary.PropositionalEquality using (_вЙ°_; _вЙҐ_)
open import Relation.Nullary using (¬ђ_)
open import Core
open import Core.MExp as M
open import Semantics.Statics.Typing using (_пЉЫ_вКҐ_вЖ¶_; _пЉЫ_вКҐ_вЖ§_)

mutual
  -- Synthesis marking: n пЉЫ ќУ вКҐ e вЖђ ƒЫ вЗС ѕД
  infix 4 _пЉЫ_вКҐ_вЖђ_вЗС_

  data _пЉЫ_вКҐ_вЖђ_вЗС_ : вДХ вЖТ Assms вЖТ Exp вЖТ MExp вЖТ Typ вЖТ Set where
    markвЖ¶*     : вИА {n ќУ} вЖТ
                   n пЉЫ ќУ вКҐ Exp.* вЖђ M.* вЗС *

    markвЖ¶вЦ°     : вИА {n ќУ} вЖТ
                   n пЉЫ ќУ вКҐ Exp.вЦ° вЖђ M.вЦ° вЗС вЦ°

    markвЖ¶Var   : вИА {n ќУ k ѕД} вЖТ
                   ќУ at k вЙ° just ѕД вЖТ
                   n пЉЫ ќУ вКҐ Exp.вЯ® k вЯ© вЖђ M.вЯ® k вЯ© вЗС ѕД

    markвЖ¶VarвЗС  : вИА {n ќУ k} вЖТ
                   ќУ at k вЙ° nothing вЖТ
                   n пЉЫ ќУ вКҐ Exp.вЯ® k вЯ© вЖђ M.вЯ® k вЯ©вЗС вЗС вЦ°

    markвЖ¶ќї:    : вИА {n ќУ e ƒЫ ѕДвВБ ѕДвВВ} вЖТ
                   n вКҐwf ѕДвВБ вЖТ
                   n пЉЫ (ѕДвВБ вИЈ ќУ) вКҐ e вЖђ ƒЫ вЗС ѕДвВВ вЖТ
                   n пЉЫ ќУ вКҐ Exp.ќї: ѕДвВБ вЗТ e вЖђ M.ќї: ѕДвВБ вЗТ ƒЫ вЗС ѕДвВБ вЗТ ѕДвВВ

    markвЖ¶ќЫ     : вИА {n ќУ e ƒЫ ѕД} вЖТ
                   suc n пЉЫ shiftќУ (suc zero) ќУ вКҐ e вЖђ ƒЫ вЗС ѕД вЖТ
                   n пЉЫ ќУ вКҐ Exp.ќЫ e вЖђ M.ќЫ ƒЫ вЗС вИА¬Ј ѕД

    markвЖ¶вИШ     : вИА {n ќУ eвВБ eвВВ ƒЫвВБ ƒЫвВВ ѕД ѕДвВБ ѕДвВВ} вЖТ
                   n пЉЫ ќУ вКҐ eвВБ вЖђ ƒЫвВБ вЗС ѕД вЖТ
                   ѕД вКФ вЦ° вЗТ вЦ° вЙ° ѕДвВБ вЗТ ѕДвВВ вЖТ
                   n пЉЫ ќУ вКҐ eвВВ вЖђ ƒЫвВВ вЗУ ѕДвВБ вЖТ
                   n пЉЫ ќУ вКҐ eвВБ Exp.вИШ eвВВ вЖђ ƒЫвВБ M.вИШ ƒЫвВВ вЗС ѕДвВВ

    markвЖ¶вИШвЗС    : вИА {n ќУ eвВБ eвВВ ƒЫвВБ ƒЫвВВ ѕД} вЖТ
                   n пЉЫ ќУ вКҐ eвВБ вЖђ ƒЫвВБ вЗС ѕД вЖТ
                   (вИА {ѕДвВБ ѕДвВВ} вЖТ ѕД вКФ вЦ° вЗТ вЦ° вЙҐ ѕДвВБ вЗТ ѕДвВВ) вЖТ
                   n пЉЫ ќУ вКҐ eвВВ вЖђ ƒЫвВВ вЗУ вЦ° вЖТ
                   n пЉЫ ќУ вКҐ eвВБ Exp.вИШ eвВВ вЖђ (ƒЫвВБ в¶ЕвЦЄвЗТв¶Ж) M.вИШ ƒЫвВВ вЗС вЦ°

    markвЖ¶<>    : вИА {n ќУ e ƒЫ ѕД ѕД' ѕГ} вЖТ
                   n пЉЫ ќУ вКҐ e вЖђ ƒЫ вЗС ѕД вЖТ
                   ѕД вКФ вИА¬Ј вЦ° вЙ° вИА¬Ј ѕД' вЖТ
                   n вКҐwf ѕГ вЖТ
                   n пЉЫ ќУ вКҐ e Exp.< ѕГ > вЖђ ƒЫ M.< ѕГ > вЗС [ zero вЖ¶ ѕГ ] ѕД'

    markвЖ¶<>вЗС   : вИА {n ќУ e ƒЫ ѕД ѕГ} вЖТ
                   n пЉЫ ќУ вКҐ e вЖђ ƒЫ вЗС ѕД вЖТ
                   (вИА {ѕД'} вЖТ ѕД вКФ вИА¬Ј вЦ° вЙҐ вИА¬Ј ѕД') вЖТ
                   n вКҐwf ѕГ вЖТ
                   n пЉЫ ќУ вКҐ e Exp.< ѕГ > вЖђ (ƒЫ в¶ЕвЦЄвИАв¶Ж) M.< ѕГ > вЗС вЦ°

    markвЖ¶&     : вИА {n ќУ eвВБ eвВВ ƒЫвВБ ƒЫвВВ ѕДвВБ ѕДвВВ} вЖТ
                   n пЉЫ ќУ вКҐ eвВБ вЖђ ƒЫвВБ вЗС ѕДвВБ вЖТ
                   n пЉЫ ќУ вКҐ eвВВ вЖђ ƒЫвВВ вЗС ѕДвВВ вЖТ
                   n пЉЫ ќУ вКҐ eвВБ Exp.& eвВВ вЖђ ƒЫвВБ M.& ƒЫвВВ вЗС ѕДвВБ √Ч ѕДвВВ

    markвЖ¶def   : вИА {n ќУ e' e ƒЫ' ƒЫ ѕД' ѕД} вЖТ
                   n пЉЫ ќУ вКҐ e' вЖђ ƒЫ' вЗС ѕД' вЖТ
                   n пЉЫ (ѕД' вИЈ ќУ) вКҐ e вЖђ ƒЫ вЗС ѕД вЖТ
                   n пЉЫ ќУ вКҐ Exp.def e' вКҐ e вЖђ M.def ƒЫ' вКҐ ƒЫ вЗС ѕД

    -- TODO: markвЖ¶ѕАвВБ, markвЖ¶ѕАвВВ, markвЖ¶case (with error variants)

  -- Analysis marking: n пЉЫ ќУ вКҐ e вЖђ ƒЫ вЗУ ѕД
  infix 4 _пЉЫ_вКҐ_вЖђ_вЗУ_

  data _пЉЫ_вКҐ_вЖђ_вЗУ_ : вДХ вЖТ Assms вЖТ Exp вЖТ MExp вЖТ Typ вЖТ Set where
    markвЖ§sub   : вИА {n ќУ e ƒЫ ѕД ѕД'} вЖТ
                   n пЉЫ ќУ вКҐ e вЖђ ƒЫ вЗС ѕД' вЖТ
                   ѕД ~ ѕД' вЖТ
                   n пЉЫ ќУ вКҐ e вЖђ ƒЫ вЗУ ѕД

    markвЖ§subвЗС  : вИА {n ќУ e ƒЫ ѕД ѕД'} вЖТ
                   n пЉЫ ќУ вКҐ e вЖђ ƒЫ вЗС ѕД' вЖТ
                   ¬ђ (ѕД ~ ѕД') вЖТ
                   n пЉЫ ќУ вКҐ e вЖђ ƒЫ в¶ЕвЙБ ѕД в¶Ж вЗУ ѕД

    markвЖ§ќї     : вИА {n ќУ e ƒЫ ѕД ѕДвВБ ѕДвВВ} вЖТ
                   ѕД вКФ вЦ° вЗТ вЦ° вЙ° ѕДвВБ вЗТ ѕДвВВ вЖТ
                   n пЉЫ (ѕДвВБ вИЈ ќУ) вКҐ e вЖђ ƒЫ вЗУ ѕДвВВ вЖТ
                   n пЉЫ ќУ вКҐ Exp.ќївЗТ e вЖђ M.ќївЗТ ƒЫ вЗУ ѕД

    markвЖ§ќївЗС    : вИА {n ќУ e ƒЫ ѕД} вЖТ
                   (вИА {ѕДвВБ ѕДвВВ} вЖТ ѕД вКФ вЦ° вЗТ вЦ° вЙҐ ѕДвВБ вЗТ ѕДвВВ) вЖТ
                   n пЉЫ ќУ вКҐ e вЖђ ƒЫ вЗУ вЦ° вЖТ
                   n пЉЫ ќУ вКҐ Exp.ќївЗТ e вЖђ (M.ќївЗТ ƒЫ) в¶Е~вЗТв¶Ж вЗУ ѕД

    markвЖ§ќї:    : вИА {n ќУ e ƒЫ ѕД ѕДвВБ ѕДвВВ} вЖТ
                   ѕД ~ ѕДвВБ вЗТ вЦ° вЖТ
                   ѕД вКФ ѕДвВБ вЗТ вЦ° вЙ° ѕДвВБ вЗТ ѕДвВВ вЖТ
                   n вКҐwf ѕДвВБ вЖТ
                   n пЉЫ (ѕДвВБ вИЈ ќУ) вКҐ e вЖђ ƒЫ вЗУ ѕДвВВ вЖТ
                   n пЉЫ ќУ вКҐ Exp.ќї: ѕДвВБ вЗТ e вЖђ M.ќї: ѕДвВБ вЗТ ƒЫ вЗУ ѕД

    markвЖ§ќєвВБ    : вИА {n ќУ e ƒЫ ѕД ѕДвВБ ѕДвВВ} вЖТ
                   ѕД вКФ вЦ° + вЦ° вЙ° ѕДвВБ + ѕДвВВ вЖТ
                   n пЉЫ ќУ вКҐ e вЖђ ƒЫ вЗУ ѕДвВБ вЖТ
                   n пЉЫ ќУ вКҐ Exp.ќєвВБ e вЖђ M.ќєвВБ ƒЫ вЗУ ѕД

    markвЖ§ќєвВВ    : вИА {n ќУ e ƒЫ ѕД ѕДвВБ ѕДвВВ} вЖТ
                   ѕД вКФ вЦ° + вЦ° вЙ° ѕДвВБ + ѕДвВВ вЖТ
                   n пЉЫ ќУ вКҐ e вЖђ ƒЫ вЗУ ѕДвВВ вЖТ
                   n пЉЫ ќУ вКҐ Exp.ќєвВВ e вЖђ M.ќєвВВ ƒЫ вЗУ ѕД

    markвЖ§&     : вИА {n ќУ eвВБ eвВВ ƒЫвВБ ƒЫвВВ ѕД ѕДвВБ ѕДвВВ} вЖТ
                   ѕД вКФ вЦ° √Ч вЦ° вЙ° ѕДвВБ √Ч ѕДвВВ вЖТ
                   n пЉЫ ќУ вКҐ eвВБ вЖђ ƒЫвВБ вЗУ ѕДвВБ вЖТ
                   n пЉЫ ќУ вКҐ eвВВ вЖђ ƒЫвВВ вЗУ ѕДвВВ вЖТ
                   n пЉЫ ќУ вКҐ eвВБ Exp.& eвВВ вЖђ ƒЫвВБ M.& ƒЫвВВ вЗУ ѕД

    markвЖ§def   : вИА {n ќУ e' e ƒЫ' ƒЫ ѕД' ѕД} вЖТ
                   n пЉЫ ќУ вКҐ e' вЖђ ƒЫ' вЗС ѕД' вЖТ
                   n пЉЫ (ѕД' вИЈ ќУ) вКҐ e вЖђ ƒЫ вЗУ ѕД вЖТ
                   n пЉЫ ќУ вКҐ Exp.def e' вКҐ e вЖђ M.def ƒЫ' вКҐ ƒЫ вЗУ ѕД

    -- TODO: markвЖ§case (with error variants)
